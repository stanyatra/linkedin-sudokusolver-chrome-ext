{
  "manifest_version": 3,

  "name": "Mini Sudoku Solver",

  "version": "1.0",

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/games/mini-sudoku/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}